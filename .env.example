# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Local server port. Defaults to 3000 when omitted.
PORT=3000

# The app uses a local Firebase-compatible mock for its hackathon workflow.
# Production starts with the mock API disabled to prevent accidental public
# exposure. Set this only for a deliberately public demo deployment.
ALLOW_INSECURE_DEMO_API=false

# Reserved for switching from the local mock to a real Firebase project.
VITE_FIREBASE_API_KEY="AIzaSyDVgqlwjMVB_CvKiex-gfpUKgsWo3gwZXk"
VITE_FIREBASE_AUTH_DOMAIN="gen-lang-client-0945812895.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="gen-lang-client-0945812895"
VITE_FIREBASE_STORAGE_BUCKET="gen-lang-client-0945812895.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="953076245915"
VITE_FIREBASE_APP_ID="1:953076245915:web:97602d91564ac0dbf12d3e"
